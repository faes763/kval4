---
import BaseLayout from "@/app/layouts/BaseLayout.astro";
import { HomeLinks } from "@/widgets/home-links";
---

<BaseLayout title="Главная">
	<div class="mx-auto max-w-lg space-y-6">
		<div>
			<h1 class="text-3xl font-semibold tracking-tight">
				Портал записи на курсы ДПО
			</h1>
			<p class="mt-2 text-muted-foreground">
				Запись на онлайн-курсы дополнительного профессионального образования.
			</p>
		</div>
		<HomeLinks client:load />
	</div>
</BaseLayout>
