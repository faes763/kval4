{
	"name": "ton-service",
	"version": "1.0.50",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "bun run --watch src/index.ts",
		"lint": "bunx --bun @biomejs/biome lint .",
		"typecheck": "bunx --bun tsc --noEmit",
		"check": "bun run lint && bun run typecheck",
		"format": "bunx --bun @biomejs/biome format --write",
		"prepare": "husky",
		"build": "bun run check && bun build --compile --minify-whitespace --minify-syntax --outfile server src/index.ts",
		"prisma:generate": "prisma generate --schema=./src/database/prisma/schema.prisma",
		"prisma:migrate": "prisma migrate dev --schema=./src/database/prisma/schema.prisma",
		"prisma:deploy": "prisma migrate deploy --schema=./src/database/prisma/schema.prisma",
		"prisma:push": "prisma db push --schema=./src/database/prisma/schema.prisma --skip-generate",
		"prisma:studio": "prisma studio --schema=./src/database/prisma/schema.prisma",
		"prisma:resolve": "prisma migrate resolve --schema=./src/database/prisma/schema.prisma"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.3.1",
		"@prisma/client": "^6.18.0",
		"@sinclair/typebox": "^0.34.15",
		"bcryptjs": "^3.0.2",
		"chalk": "^5.6.2",
		"elysia": "latest",
		"jose": "^6.1.0",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"bun-types": "latest",
		"dotenv": "^17.4.2",
		"husky": "^9.1.7",
		"prisma": "^6.18.0"
	},
	"module": "src/index.js"
}
