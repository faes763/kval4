# Runtime environment: dev | development | stage | prod
APP_ENV=prod

# Postgres: docker-compose маппит POSTGRES_PORT на контейнер :5432
POSTGRES_PORT=5432
POSTGRES_PORT_DEV=5432
POSTGRES_PORT_STAGE=5433
POSTGRES_PORT_PROD=5434

# Postgres auth
POSTGRES_USER=ciel
POSTGRES_PASSWORD=system
POSTGRES_DB=system-dev

# App ports (проброс docker-compose)
SERVER_HOST=127.0.0.1
SERVER_PORT=4444
WEB_PORT=4443

# URL API для сборки Astro (браузер). На сервере замените 127.0.0.1 на IP/домен машины.
PUBLIC_API_URL=http://127.0.0.1:4444
