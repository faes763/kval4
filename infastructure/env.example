# Скопируйте в .env: cp env.example .env
APP_ENV=prod

POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=app-db

SERVER_PORT=4000
WEB_PORT=3000

# URL API для сборки Astro (браузер → хост:порт как на сервере)
PUBLIC_API_URL=http://127.0.0.1:4000

# Опционально: registry для bun/npm при docker build (по умолчанию npmmirror)
# NPM_REGISTRY=https://registry.npmjs.org
